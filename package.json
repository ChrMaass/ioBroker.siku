{
  "name": "iobroker.siku",
  "version": "0.1.2",
  "description": "ioBroker adapter for SIKU RV V2 ventilation devices",
  "author": {
    "name": "Christian Maaß",
    "email": "christian@maass.it"
  },
  "contributors": [],
  "homepage": "https://github.com/ChrMaass/ioBroker.siku",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "siku",
    "ventilation",
    "fan",
    "udp",
    "rv v2"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ChrMaass/ioBroker.siku.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/dev-server": "^0.8.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/iobroker": "npm:@iobroker/types@^7.1.1",
    "@types/node": "^20.19.39",
    "nyc": "^18.0.0",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "www/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "node --experimental-require-module ./node_modules/@iobroker/adapter-dev/bin/build-adapter.js ts",
    "watch": "node --experimental-require-module ./node_modules/@iobroker/adapter-dev/bin/build-adapter.js ts --watch",
    "prebuild:ts": "rimraf build",
    "build:ts": "node --experimental-require-module ./node_modules/@iobroker/adapter-dev/bin/build-adapter.js ts",
    "watch:ts": "node --experimental-require-module ./node_modules/@iobroker/adapter-dev/bin/build-adapter.js ts --watch",
    "test:ts": "mocha --config test/mocharc.custom.json src/**/*.test.ts",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "check": "tsc --noEmit",
    "coverage": "nyc npm run test:ts",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script",
    "dev-server": "dev-server"
  },
  "nyc": {
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/*.test.ts"
    ],
    "extension": [
      ".ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "reporter": [
      "text-summary",
      "html"
    ],
    "sourceMap": true,
    "instrument": true
  },
  "bugs": {
    "url": "https://github.com/ChrMaass/ioBroker.siku/issues"
  },
  "readmeFilename": "README.md"
}
